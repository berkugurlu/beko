{
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "redirects": [
    {
      "source": "https://www.vuelina.com/:path*",
      "destination": "https://vuelina.com/:path*",
      "permanent": true
    },
    {
      "source": "http://www.vuelina.com/:path*",
      "destination": "https://vuelina.com/:path*",
      "permanent": true
    },
    {
      "source": "http://vuelina.com/:path*",
      "destination": "https://vuelina.com/:path*",
      "permanent": true
    }
  ]
}
